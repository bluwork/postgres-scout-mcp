{
  "name": "postgres-scout-mcp",
  "version": "0.1.0",
  "description": "Production-ready Model Context Protocol server for safe PostgreSQL database interaction",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "postgres-scout-mcp": "./bin/cli.js",
    "postgres-scout": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bluwork/postgres-scout-mcp"
  },
  "files": [
    "dist",
    "!dist/**/*.js.map",
    "!dist/**/*.d.ts.map",
    "!dist/**/*.d.ts",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "postgres",
    "postgresql",
    "database",
    "sql",
    "ai",
    "llm",
    "claude",
    "anthropic",
    "database-monitoring",
    "query-optimization",
    "schema-analysis",
    "data-quality",
    "database-explorer",
    "sql-analysis",
    "database-health",
    "index-optimization"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "author": "Boban Lukic",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.1",
    "pg": "^8.11.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@types/pg": "^8.10.9",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
