{
  "name": "postgres-scout-mcp",
  "version": "1.0.0",
  "description": "Scout your PostgreSQL databases with AI - A production-ready MCP server with safety features, monitoring, and data quality tools",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "watch": "tsc --watch",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "chmod +x bin/cli.js"
  },
  "bin": {
    "postgres-scout-mcp": "./bin/cli.js",
    "postgres-scout": "./bin/cli.js"
  },
  "keywords": [
    "postgresql",
    "mcp",
    "model-context-protocol",
    "ai-assistant",
    "claude",
    "database"
  ],
  "author": "Boban Lukic",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bluwork/postgres-scout-mcp"
  },
  "files": [
    "dist",
    "!dist/**/*.js.map",
    "!dist/**/*.d.ts.map",
    "!dist/**/*.d.ts",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.1",
    "pg": "^8.11.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@types/pg": "^8.10.9",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
